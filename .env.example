# Next.js Environment Variables

# API Keys (To be added in Step 2+)
NEXT_PUBLIC_LIVEPEER_API_KEY=your_livepeer_api_key_here
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud
NEXT_PUBLIC_ARWEAVE_HOST=arweave.net

# Web3 Configuration (Step 2)
NEXT_PUBLIC_INFURA_KEY=your_infura_key_here
NEXT_PUBLIC_ALCHEMY_KEY=your_alchemy_key_here
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Smart Contracts (Step 3)
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-rpc.com
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_MEMBERSHIP_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_AD_ENGINE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Database & Indexing (Phase 2)
NEXT_PUBLIC_GRAPH_QUERY_ENDPOINT=https://api.thegraph.com/subgraphs/name/your_subgraph
DATABASE_URL=postgresql://user:password@localhost:5432/web3video

# Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=your_analytics_id_here

# Development
NODE_ENV=development
NEXT_PUBLIC_DEBUG=false
